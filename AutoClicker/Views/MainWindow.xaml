<Window x:Class="AutoClicker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:viewModels="clr-namespace:AutoClicker.ViewModels"
        xmlns:models="clr-namespace:AutoClicker.Models"
        mc:Ignorable="d"
        Title="AutoClicker" Height="600" Width="1200"
        x:Name="Root"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Closing="MainWindow_OnClosing">
    <Window.Resources>
        <Style x:Key="ContentBorder"
            TargetType="Border">
            <Setter
                Property="Background"
                Value="White" />
            <Setter
                Property="CornerRadius"
                Value="10" />
            <Setter
                Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        Color="#EEE"
                        ShadowDepth="3" />
                </Setter.Value>
            </Setter>
            <Setter
                Property="Padding"
                Value="10" />

            <Style.Triggers>
                <Trigger
                    Property="IsMouseOver"
                    Value="True">
                    <Setter
                        Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect
                                Color="#DDD"
                                ShadowDepth="3" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>
    <Grid>
        <Grid
            Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Style="{StaticResource ContentBorder}">

                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style
                            TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsRecording}"
                                    Value="True">
                                    <Setter
                                        Property="IsEnabled"
                                        Value="False" />
                                </DataTrigger>
                                <DataTrigger
                                    Binding="{Binding IsRunning}"
                                    Value="True">
                                    <Setter
                                        Property="IsEnabled"
                                        Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:Button
                        Command="{Binding OpenFileCommand}"
                        Content="Open File..." />
                    <ui:Button
                        Command="{Binding CreateNewFileCommand}"
                        Content="New File"
                        Margin="10, 0"/>
                    <ui:Button
                        Command="{Binding SaveFileCommand}"
                        Content="Save"/>
                    <ui:Button
                        Command="{Binding SaveFileAsCommand}"
                        Content="Save As..."
                        Margin="10, 0"/>
                    <Separator/>
                    <ui:Button
                        Command="{Binding StartRecordingCommand}"
                        Content="Start Recording..."
                        Margin="10, 0" />
                    <ui:Button
                        Command="{Binding StartRunningCommand}"
                        Content="Start Running..."/>
                    <Label
                        Content="Stop key:"
                        Margin="10, 0, 0, 0"
                        Target="{Binding ElementName=CbxStopKey}" />
                    <ComboBox
                        x:Name="CbxStopKey"
                        SelectedItem="{Binding StopKey}"
                        Width="100" />
                    <CheckBox
                        IsChecked="{Binding CaptureMouseMovement, UpdateSourceTrigger=PropertyChanged}"
                        Margin="10, 0, -10, 0">
                    </CheckBox>
                    <Label
                        Content="Mouse precision (ms):"
                        Target="{Binding ElementName=NbxPrecision}" />
                    <ui:NumberBox
                        x:Name="NbxPrecision"
                        ClearButtonEnabled="False"
                        IsEnabled="{Binding CaptureMouseMovement}"
                        Minimum="0"
                        MinWidth="100"
                        Value="{Binding MouseCapturePrecision, UpdateSourceTrigger=PropertyChanged}" />
                    <ToggleButton
                        x:Name="TbgHelp"
                        Content="{ui:SymbolIcon ChatHelp24, FontSize='20'}"
                        Margin="10, 0, 0, 0"
                        Padding="5"
                        ToolTip="Help..." />
                </StackPanel>
            </Border>

            <ui:TextBox
                Grid.Row="1"
                AcceptsReturn="True"
                AcceptsTab="True"
                ClearButtonEnabled="False"
                HorizontalScrollBarVisibility="Visible"
                Margin="0, 10, 0, 0"
                Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                VerticalScrollBarVisibility="Visible">
                <ui:TextBox.Style>
                    <!-- ReSharper disable once Xaml.StaticResourceNotResolved -->
                    <Style
                        TargetType="ui:TextBox"
                        BasedOn="{StaticResource {x:Type ui:TextBox}}">
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsRecording}"
                                Value="True">
                                <Setter
                                    Property="IsEnabled"
                                    Value="False" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsRunning}"
                                Value="True">
                                <Setter
                                    Property="IsEnabled"
                                    Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:TextBox.Style>
            </ui:TextBox>

            <Border
                Grid.Row="1"
                Margin="0, 10, 0, 0"
                Style="{StaticResource ContentBorder}"
                Visibility="{Binding IsChecked, ElementName=TbgHelp, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ui:TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Text="Commands" />
                        <ItemsControl
                            ItemsSource="{Binding HelpTopics}"
                            Margin="0, 20, 0, 0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate
                                    DataType="{x:Type models:HelpTopic}">
                                    <StackPanel>
                                        <StackPanel
                                            Orientation="Horizontal">
                                            <ui:Button
                                                Command="{Binding DataContext.CopyToClipboardCommand, ElementName=Root}"
                                                CommandParameter="{Binding CommandText}"
                                                Content="{ui:SymbolIcon Copy24, FontSize='20'}"
                                                Margin="0, 0, 10, 0"
                                                Padding="5">
                                                <ui:Button.ToolTip>
                                                    <ui:TextBlock
                                                        Text="{Binding CommandText, StringFormat='{}Copy &quot;{0}&quot; to Clipboard.'}" />
                                                </ui:Button.ToolTip>
                                            </ui:Button>
                                            <ui:TextBlock
                                                FontSize="17"
                                                FontWeight="DemiBold"
                                                Text="{Binding Title}"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ui:TextBlock
                                            Margin="0, 5, 0, 20"
                                            Text="{Binding Description}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <ContentPresenter
            x:Name="CtpPopup" />
    </Grid>
</Window>
